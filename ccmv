#!/bin/bash

# ccmv: Claude Code Project Directory Migration Tool
# Moves a project directory and updates all Claude Code references

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default options
DRY_RUN=false
REFS_ONLY=false
KEEP_BACKUP=false
VERBOSE=true

# Globals
BACKUP_DIR=""
OLD_PATH=""
NEW_PATH=""
ENCODED_OLD=""
ENCODED_NEW=""
CLAUDE_DIR="${HOME}/.claude"
PROJECTS_DIR="${CLAUDE_DIR}/projects"
HISTORY_FILE="${CLAUDE_DIR}/history.jsonl"

# Cursor specific
CURSOR_SKIP=false
CURSOR_DETECTED=false
CURSOR_APP_SUPPORT="${HOME}/Library/Application Support/Cursor"
CURSOR_USER_DIR="${CURSOR_APP_SUPPORT}/User"
CURSOR_GLOBAL_STORAGE="${CURSOR_USER_DIR}/globalStorage"
CURSOR_WORKSPACE_STORAGE="${CURSOR_USER_DIR}/workspaceStorage"
CURSOR_STORAGE_JSON="${CURSOR_GLOBAL_STORAGE}/storage.json"
CURSOR_STATE_VSCDB="${CURSOR_GLOBAL_STORAGE}/state.vscdb"
OLD_FILE_URI=""
NEW_FILE_URI=""
CURSOR_WORKSPACE_DIRS=()

# Logging functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_ok() {
    echo -e "${GREEN}[OK]${NC} $1"
}

log_check() {
    echo -e "${YELLOW}[CHECK]${NC} $1"
}

log_backup() {
    echo -e "${YELLOW}[BACKUP]${NC} $1"
}

log_file() {
    echo -e "${BLUE}[FILE]${NC} $1"
}

log_replace() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo -e "  ${GREEN}[REPLACE]${NC} $1"
    fi
}

log_rename() {
    echo -e "${BLUE}[RENAME]${NC} $1"
}

log_done() {
    echo -e "${GREEN}[DONE]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_rollback() {
    echo -e "${YELLOW}[ROLLBACK]${NC} $1"
}

log_dryrun() {
    echo -e "${YELLOW}[DRY-RUN]${NC} $1"
}

# Show usage
usage() {
    cat << EOF
Usage: ccmv [OPTIONS] <old-path> <new-path>

Moves a project directory and updates all Claude Code references.
If Cursor is installed, also updates Cursor's workspace data automatically.

Options:
  --refs-only    Only update Claude's references (don't move the actual directory)
  --dry-run      Show what would be done without making changes
  --keep-backup  Don't remove backups after successful migration
  --no-cursor    Skip Cursor data updates even if Cursor is installed
  --verbose      Show detailed logs (default: on)
  --quiet        Suppress detailed logs
  --help         Show this help message

Examples:
  ccmv /Users/jane/old-project /Users/jane/new-project
  ccmv --dry-run ~/projects/myapp ~/work/myapp
  ccmv --refs-only /old/path /new/path
  ccmv --no-cursor ~/proj-a ~/proj-b

EOF
    exit 0
}

# Encode path for Claude projects directory
# Rule: / -> -, : -> -, space -> -
encode_path() {
    local path="$1"
    # Replace /, :, and space with -
    echo "$path" | sed 's/[\/: ]/-/g'
}

# Escape path for sed regex (using | as delimiter)
escape_sed() {
    local path="$1"
    # Escape special characters: | \ & . [ ] ^ $ *
    # Note: / doesn't need escaping since we use | as delimiter
    printf '%s\n' "$path" | sed 's/[|&.*^$[\\]/\\&/g'
}

# Convert filesystem path to file:// URI with URL encoding
path_to_file_uri() {
    local path="$1"
    python3 -c "from urllib.parse import quote; print('file://' + quote('$path', safe='/'))"
}

# Detect if Cursor is installed
detect_cursor() {
    if [[ "$CURSOR_SKIP" == "true" ]]; then
        log_info "Cursor update skipped (--no-cursor)"
        return
    fi

    if [[ -d "$CURSOR_USER_DIR" ]]; then
        CURSOR_DETECTED=true
        log_ok "Cursor detected"
    else
        log_info "Cursor not installed, skipping"
    fi
}

# Check if Cursor is running
check_cursor_not_running() {
    if [[ "$CURSOR_DETECTED" != "true" ]]; then
        return
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        return
    fi

    if pgrep -x "Cursor" > /dev/null 2>&1; then
        log_error "Cursor is running. Please close Cursor before migration to prevent data corruption."
        exit 1
    fi
    log_ok "Cursor is not running"
}

# Find workspace directories that contain the old path
find_cursor_workspaces() {
    if [[ "$CURSOR_DETECTED" != "true" ]]; then
        return
    fi

    if [[ ! -d "$CURSOR_WORKSPACE_STORAGE" ]]; then
        return
    fi

    log_info "Scanning Cursor workspace storage..."

    # Search for workspace.json files containing our path
    local workspace_dir
    for workspace_dir in "$CURSOR_WORKSPACE_STORAGE"/*/; do
        local workspace_json="${workspace_dir}workspace.json"
        if [[ -f "$workspace_json" ]]; then
            # Check both 'folder' and 'workspace' keys (ccdiary approach)
            if grep -q "$OLD_FILE_URI" "$workspace_json" 2>/dev/null; then
                CURSOR_WORKSPACE_DIRS+=("$workspace_dir")
                local dirname
                dirname=$(basename "$workspace_dir")
                log_info "  Found workspace: $dirname"
            fi
        fi
    done

    local count=${#CURSOR_WORKSPACE_DIRS[@]}
    if [[ $count -gt 0 ]]; then
        log_ok "Found $count workspace directory(s) to update"
    else
        log_info "No matching Cursor workspaces found"
    fi
}

# Backup Cursor data
backup_cursor_data() {
    if [[ "$CURSOR_DETECTED" != "true" ]]; then
        return
    fi

    log_backup "Backing up Cursor data..."

    if [[ "$DRY_RUN" == "true" ]]; then
        log_dryrun "Would backup Cursor data"
        return
    fi

    mkdir -p "$BACKUP_DIR/cursor/workspaces"

    # Backup storage.json
    if [[ -f "$CURSOR_STORAGE_JSON" ]]; then
        cp "$CURSOR_STORAGE_JSON" "$BACKUP_DIR/cursor/"
        log_backup "storage.json"
    fi

    # Backup global state.vscdb
    if [[ -f "$CURSOR_STATE_VSCDB" ]]; then
        cp "$CURSOR_STATE_VSCDB" "$BACKUP_DIR/cursor/"
        log_backup "state.vscdb (global)"
    fi

    # Backup workspace directories
    local workspace_dir
    for workspace_dir in "${CURSOR_WORKSPACE_DIRS[@]}"; do
        local dirname
        dirname=$(basename "$workspace_dir")
        cp -R "$workspace_dir" "$BACKUP_DIR/cursor/workspaces/"
        log_backup "workspace: $dirname"
    done

    echo ""
}

# Update Cursor storage.json
update_cursor_storage_json() {
    if [[ "$CURSOR_DETECTED" != "true" ]]; then
        return
    fi

    if [[ ! -f "$CURSOR_STORAGE_JSON" ]]; then
        return
    fi

    log_info "Updating Cursor storage.json..."

    local escaped_old
    local escaped_new
    escaped_old=$(escape_sed "$OLD_FILE_URI")
    escaped_new=$(escape_sed "$NEW_FILE_URI")

    # Count occurrences
    local count
    count=$(grep -c "$OLD_FILE_URI" "$CURSOR_STORAGE_JSON" 2>/dev/null) || count=0

    if [[ "$count" -gt 0 ]]; then
        if [[ "$DRY_RUN" == "true" ]]; then
            log_replace "$count occurrences would be updated"
        else
            sed -i '' "s|${escaped_old}|${escaped_new}|g" "$CURSOR_STORAGE_JSON"
            log_replace "$count occurrences updated"
        fi
    else
        log_info "No matching entries in storage.json"
    fi

    echo ""
}

# Update Cursor global state.vscdb (SQLite)
update_cursor_state_vscdb() {
    if [[ "$CURSOR_DETECTED" != "true" ]]; then
        return
    fi

    if [[ ! -f "$CURSOR_STATE_VSCDB" ]]; then
        return
    fi

    log_info "Updating Cursor global state.vscdb..."

    # Escape single quotes for SQL
    local escaped_old="${OLD_FILE_URI//\'/\'\'}"
    local escaped_new="${NEW_FILE_URI//\'/\'\'}"

    if [[ "$DRY_RUN" == "true" ]]; then
        # Count matching rows
        local count
        count=$(sqlite3 "$CURSOR_STATE_VSCDB" \
            "SELECT COUNT(*) FROM ItemTable WHERE value LIKE '%${escaped_old}%';" 2>/dev/null) || count=0
        log_replace "$count rows would be updated"
    else
        sqlite3 "$CURSOR_STATE_VSCDB" << EOF
BEGIN TRANSACTION;
UPDATE ItemTable
SET value = REPLACE(value, '${escaped_old}', '${escaped_new}')
WHERE value LIKE '%${escaped_old}%';
COMMIT;
EOF
        local count
        count=$(sqlite3 "$CURSOR_STATE_VSCDB" "SELECT changes();" 2>/dev/null) || count=0
        log_replace "$count rows updated"
    fi

    echo ""
}

# Update Cursor workspace storage
update_cursor_workspace_storage() {
    if [[ "$CURSOR_DETECTED" != "true" ]]; then
        return
    fi

    if [[ ${#CURSOR_WORKSPACE_DIRS[@]} -eq 0 ]]; then
        return
    fi

    log_info "Updating Cursor workspace storage..."

    local escaped_old
    local escaped_new
    escaped_old=$(escape_sed "$OLD_FILE_URI")
    escaped_new=$(escape_sed "$NEW_FILE_URI")

    # SQL escaped versions
    local sql_escaped_old="${OLD_FILE_URI//\'/\'\'}"
    local sql_escaped_new="${NEW_FILE_URI//\'/\'\'}"

    local workspace_dir
    for workspace_dir in "${CURSOR_WORKSPACE_DIRS[@]}"; do
        local dirname
        dirname=$(basename "$workspace_dir")
        log_file "Workspace: $dirname"

        # Update workspace.json
        local workspace_json="${workspace_dir}workspace.json"
        if [[ -f "$workspace_json" ]]; then
            local count
            count=$(grep -c "$OLD_FILE_URI" "$workspace_json" 2>/dev/null) || count=0
            if [[ "$count" -gt 0 ]]; then
                if [[ "$DRY_RUN" == "true" ]]; then
                    log_replace "workspace.json: $count occurrences would be updated"
                else
                    sed -i '' "s|${escaped_old}|${escaped_new}|g" "$workspace_json"
                    log_replace "workspace.json: $count occurrences updated"
                fi
            fi
        fi

        # Update state.vscdb
        local state_vscdb="${workspace_dir}state.vscdb"
        if [[ -f "$state_vscdb" ]]; then
            if [[ "$DRY_RUN" == "true" ]]; then
                local count
                count=$(sqlite3 "$state_vscdb" \
                    "SELECT COUNT(*) FROM ItemTable WHERE value LIKE '%${sql_escaped_old}%';" 2>/dev/null) || count=0
                if [[ "$count" -gt 0 ]]; then
                    log_replace "state.vscdb: $count rows would be updated"
                fi
            else
                sqlite3 "$state_vscdb" << EOF
BEGIN TRANSACTION;
UPDATE ItemTable
SET value = REPLACE(value, '${sql_escaped_old}', '${sql_escaped_new}')
WHERE value LIKE '%${sql_escaped_old}%';
COMMIT;
EOF
                local count
                count=$(sqlite3 "$state_vscdb" "SELECT changes();" 2>/dev/null) || count=0
                if [[ "$count" -gt 0 ]]; then
                    log_replace "state.vscdb: $count rows updated"
                fi
            fi
        fi
    done

    echo ""
}

# Verify Cursor migration
verify_cursor_migration() {
    if [[ "$CURSOR_DETECTED" != "true" ]]; then
        return
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        return
    fi

    log_info "Verifying Cursor migration..."

    local has_error=false

    # Check storage.json
    if [[ -f "$CURSOR_STORAGE_JSON" ]]; then
        local count
        count=$(grep -c "$OLD_FILE_URI" "$CURSOR_STORAGE_JSON" 2>/dev/null) || count=0
        if [[ "$count" -gt 0 ]]; then
            log_error "Found $count stale references in storage.json"
            has_error=true
        fi
    fi

    # Check global state.vscdb
    if [[ -f "$CURSOR_STATE_VSCDB" ]]; then
        local escaped_old="${OLD_FILE_URI//\'/\'\'}"
        local count
        count=$(sqlite3 "$CURSOR_STATE_VSCDB" \
            "SELECT COUNT(*) FROM ItemTable WHERE value LIKE '%${escaped_old}%';" 2>/dev/null) || count=0
        if [[ "$count" -gt 0 ]]; then
            log_error "Found $count stale references in global state.vscdb"
            has_error=true
        fi
    fi

    # Check workspace directories
    local workspace_dir
    for workspace_dir in "${CURSOR_WORKSPACE_DIRS[@]}"; do
        local workspace_json="${workspace_dir}workspace.json"
        if [[ -f "$workspace_json" ]]; then
            local count
            count=$(grep -c "$OLD_FILE_URI" "$workspace_json" 2>/dev/null) || count=0
            if [[ "$count" -gt 0 ]]; then
                log_error "Found $count stale references in $(basename "$workspace_dir")/workspace.json"
                has_error=true
            fi
        fi
    done

    if [[ "$has_error" == "true" ]]; then
        return 1
    fi

    log_ok "Cursor migration verified"
    echo ""
}

# Rollback function
rollback() {
    local exit_code=$?

    if [[ -z "$BACKUP_DIR" ]] || [[ ! -d "$BACKUP_DIR" ]]; then
        log_error "No backup available for rollback"
        exit 1
    fi

    log_error "Migration failed! Rolling back..."

    # Restore history.jsonl
    if [[ -f "$BACKUP_DIR/history.jsonl" ]]; then
        cp "$BACKUP_DIR/history.jsonl" "$HISTORY_FILE"
        log_rollback "Restored history.jsonl"
    fi

    # Restore project dir if it was renamed
    local old_project_dir="${PROJECTS_DIR}/${ENCODED_OLD}"
    local new_project_dir="${PROJECTS_DIR}/${ENCODED_NEW}"

    if [[ -d "$BACKUP_DIR/projects/${ENCODED_OLD}" ]]; then
        if [[ -d "$new_project_dir" ]]; then
            rm -rf "$new_project_dir"
        fi
        cp -R "$BACKUP_DIR/projects/${ENCODED_OLD}" "$old_project_dir"
        log_rollback "Restored project directory"
    fi

    # Restore original project location if moved
    if [[ "$REFS_ONLY" != "true" ]]; then
        if [[ -d "$NEW_PATH" ]] && [[ ! -d "$OLD_PATH" ]]; then
            mv "$NEW_PATH" "$OLD_PATH"
            log_rollback "Moved project back to original location"
        fi
    fi

    # Restore Cursor data
    if [[ "$CURSOR_DETECTED" == "true" ]]; then
        if [[ -f "$BACKUP_DIR/cursor/storage.json" ]]; then
            cp "$BACKUP_DIR/cursor/storage.json" "$CURSOR_STORAGE_JSON"
            log_rollback "Restored Cursor storage.json"
        fi
        if [[ -f "$BACKUP_DIR/cursor/state.vscdb" ]]; then
            cp "$BACKUP_DIR/cursor/state.vscdb" "$CURSOR_STATE_VSCDB"
            log_rollback "Restored Cursor global state.vscdb"
        fi
        # Restore workspace directories
        if [[ -d "$BACKUP_DIR/cursor/workspaces" ]]; then
            local backup_workspace
            for backup_workspace in "$BACKUP_DIR/cursor/workspaces"/*/; do
                if [[ -d "$backup_workspace" ]]; then
                    local dirname
                    dirname=$(basename "$backup_workspace")
                    local target_dir="${CURSOR_WORKSPACE_STORAGE}/${dirname}"
                    rm -rf "$target_dir"
                    cp -R "$backup_workspace" "$target_dir"
                    log_rollback "Restored Cursor workspace: $dirname"
                fi
            done
        fi
    fi

    log_rollback "Complete. Your project is unchanged."
    echo ""
    echo "Backup kept at: $BACKUP_DIR"

    exit "$exit_code"
}

# Validate paths and environment
validate() {
    log_check "Validating paths..."

    # Check old path exists
    if [[ ! -d "$OLD_PATH" ]]; then
        if [[ "$REFS_ONLY" == "true" ]]; then
            log_info "Old path doesn't exist (OK for --refs-only mode)"
        else
            log_error "Old path does not exist: $OLD_PATH"
            exit 1
        fi
    else
        log_ok "Old path exists"
    fi

    # Check new path doesn't exist (unless refs-only)
    if [[ "$REFS_ONLY" != "true" ]]; then
        if [[ -e "$NEW_PATH" ]]; then
            log_error "New path already exists: $NEW_PATH"
            exit 1
        fi
        log_ok "New path does not exist"
    fi

    # Check Claude project dir exists
    local old_project_dir="${PROJECTS_DIR}/${ENCODED_OLD}"
    if [[ -d "$old_project_dir" ]]; then
        log_ok "Claude project dir exists: ${old_project_dir/#$HOME/\~}/"
    else
        log_error "Claude project directory not found: ${old_project_dir/#$HOME/\~}/"
        log_error "This project may not have any Claude Code history."
        exit 1
    fi

    echo ""
}

# Create backups
create_backup() {
    local timestamp
    timestamp=$(date +%Y%m%d-%H%M%S)
    BACKUP_DIR="${CLAUDE_DIR}/backups/ccmv-${timestamp}"

    log_backup "Creating backups..."

    if [[ "$DRY_RUN" == "true" ]]; then
        log_dryrun "Would create backup at: ${BACKUP_DIR/#$HOME/\~}/"
        return
    fi

    mkdir -p "$BACKUP_DIR/projects"

    # Backup project directory
    local old_project_dir="${PROJECTS_DIR}/${ENCODED_OLD}"
    if [[ -d "$old_project_dir" ]]; then
        cp -R "$old_project_dir" "$BACKUP_DIR/projects/"
        log_backup "${old_project_dir/#$HOME/\~}/ -> ${BACKUP_DIR/#$HOME/\~}/projects/"
    fi

    # Backup history.jsonl
    if [[ -f "$HISTORY_FILE" ]]; then
        cp "$HISTORY_FILE" "$BACKUP_DIR/"
        log_backup "${HISTORY_FILE/#$HOME/\~} -> ${BACKUP_DIR/#$HOME/\~}/history.jsonl"
    fi

    echo ""
}

# Move the actual project directory
move_project() {
    if [[ "$REFS_ONLY" == "true" ]]; then
        return
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        log_dryrun "Would move: $OLD_PATH -> $NEW_PATH"
        echo ""
        return
    fi

    log_info "Moving project directory..."
    mv "$OLD_PATH" "$NEW_PATH"
    log_ok "Moved: $OLD_PATH -> $NEW_PATH"
    echo ""
}

# Update all files containing cwd field in Claude projects directory
update_project_files() {
    local project_dir="${PROJECTS_DIR}/${ENCODED_NEW}"
    local escaped_old
    local escaped_new

    # For dry-run, use old path since rename hasn't happened yet
    if [[ "$DRY_RUN" == "true" ]]; then
        project_dir="${PROJECTS_DIR}/${ENCODED_OLD}"
    fi

    log_info "Updating project files..."

    escaped_old=$(escape_sed "$OLD_PATH")
    escaped_new=$(escape_sed "$NEW_PATH")

    # Find all files containing the old cwd pattern (includes .jsonl and tool-results/*.txt)
    local files_with_cwd
    files_with_cwd=$(grep -rl "\"cwd\":\"${OLD_PATH}\"" "$project_dir" 2>/dev/null || true)

    if [[ -z "$files_with_cwd" ]]; then
        log_info "No files with cwd field found"
        echo ""
        return
    fi

    local file
    for file in $files_with_cwd; do
        local relpath="${file#$project_dir/}"

        # Count occurrences
        local count
        count=$(grep -c "\"cwd\":\"${OLD_PATH}\"" "$file" 2>/dev/null) || count=0

        if [[ "$count" -gt 0 ]]; then
            log_file "$relpath"

            if [[ "$DRY_RUN" == "true" ]]; then
                log_replace "$count occurrences would be updated"
            else
                # Perform replacement (using | as delimiter to avoid path escaping issues)
                sed -i '' "s|\"cwd\":\"${escaped_old}\"|\"cwd\":\"${escaped_new}\"|g" "$file"
                log_replace "$count occurrences updated"
            fi
        fi
    done

    echo ""
}

# Update global history file
update_history() {
    if [[ ! -f "$HISTORY_FILE" ]]; then
        log_info "No global history file found"
        echo ""
        return
    fi

    log_info "Updating global history..."

    local escaped_old
    local escaped_new
    escaped_old=$(escape_sed "$OLD_PATH")
    escaped_new=$(escape_sed "$NEW_PATH")

    # Count occurrences
    local count
    count=$(grep -c "\"cwd\":\"${OLD_PATH}\"" "$HISTORY_FILE" 2>/dev/null) || count=0

    if [[ "$count" -gt 0 ]]; then
        if [[ "$DRY_RUN" == "true" ]]; then
            log_replace "$count entries would be updated"
        else
            sed -i '' "s|\"cwd\":\"${escaped_old}\"|\"cwd\":\"${escaped_new}\"|g" "$HISTORY_FILE"
            log_replace "$count entries updated"
        fi
    else
        log_info "No matching entries found in history"
    fi

    echo ""
}

# Rename Claude projects directory
rename_claude_dir() {
    local old_project_dir="${PROJECTS_DIR}/${ENCODED_OLD}"
    local new_project_dir="${PROJECTS_DIR}/${ENCODED_NEW}"

    if [[ "$DRY_RUN" == "true" ]]; then
        log_dryrun "Would rename: ${old_project_dir/#$HOME/\~}/ -> ${new_project_dir/#$HOME/\~}/"
        echo ""
        return
    fi

    log_rename "${old_project_dir/#$HOME/\~}/ -> ${new_project_dir/#$HOME/\~}/"
    mv "$old_project_dir" "$new_project_dir"

    echo ""
}

# Verify the migration
verify() {
    log_info "Verifying migration..."

    if [[ "$DRY_RUN" == "true" ]]; then
        log_dryrun "Verification skipped in dry-run mode"
        echo ""
        return
    fi

    local new_project_dir="${PROJECTS_DIR}/${ENCODED_NEW}"

    # Check new Claude projects dir exists
    if [[ -d "$new_project_dir" ]]; then
        log_ok "New Claude project dir exists"
    else
        log_error "New Claude project dir not found!"
        return 1
    fi

    # Check JSONL files are valid (spot check first file)
    local first_jsonl
    first_jsonl=$(find "$new_project_dir" -name "*.jsonl" -type f | head -1)

    if [[ -n "$first_jsonl" ]]; then
        # Try to parse first line as JSON
        if head -1 "$first_jsonl" | python3 -m json.tool > /dev/null 2>&1; then
            log_ok "JSONL files appear valid"
        else
            log_error "JSONL file may be corrupted: $first_jsonl"
            return 1
        fi
    fi

    # Verify no old path references remain
    local remaining
    remaining=$(grep -rc "\"cwd\":\"${OLD_PATH}\"" "$new_project_dir" 2>/dev/null | awk -F: '{sum += $2} END {print sum+0}') || remaining=0

    if [[ "$remaining" -gt 0 ]]; then
        log_error "Found $remaining remaining references to old path!"
        return 1
    fi
    log_ok "No stale path references found"

    echo ""
}

# Cleanup backups
cleanup() {
    if [[ "$DRY_RUN" == "true" ]]; then
        return
    fi

    if [[ "$KEEP_BACKUP" == "true" ]]; then
        log_info "Backup kept at: ${BACKUP_DIR/#$HOME/\~}/"
    else
        if [[ -n "$BACKUP_DIR" ]] && [[ -d "$BACKUP_DIR" ]]; then
            rm -rf "$BACKUP_DIR"
            log_info "Backup removed"
        fi
    fi
}

# Main function
main() {
    # Parse arguments
    local positional=()

    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            --refs-only)
                REFS_ONLY=true
                shift
                ;;
            --keep-backup)
                KEEP_BACKUP=true
                shift
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            --quiet)
                VERBOSE=false
                shift
                ;;
            --no-cursor)
                CURSOR_SKIP=true
                shift
                ;;
            --help|-h)
                usage
                ;;
            -*)
                log_error "Unknown option: $1"
                echo "Use --help for usage information"
                exit 1
                ;;
            *)
                positional+=("$1")
                shift
                ;;
        esac
    done

    # Check positional arguments
    if [[ ${#positional[@]} -ne 2 ]]; then
        log_error "Expected 2 arguments: old-path and new-path"
        echo "Use --help for usage information"
        exit 1
    fi

    # Resolve to absolute paths
    OLD_PATH=$(cd "$(dirname "${positional[0]}")" 2>/dev/null && pwd)/$(basename "${positional[0]}")
    OLD_PATH="${OLD_PATH%/}"  # Remove trailing slash

    # For new path, we can't cd into it (it doesn't exist), so resolve parent
    local new_parent
    local new_name
    new_parent=$(cd "$(dirname "${positional[1]}")" 2>/dev/null && pwd)
    new_name=$(basename "${positional[1]}")
    NEW_PATH="${new_parent}/${new_name}"
    NEW_PATH="${NEW_PATH%/}"  # Remove trailing slash

    # Encode paths
    ENCODED_OLD=$(encode_path "$OLD_PATH")
    ENCODED_NEW=$(encode_path "$NEW_PATH")

    # Generate file:// URIs for Cursor
    OLD_FILE_URI=$(path_to_file_uri "$OLD_PATH")
    NEW_FILE_URI=$(path_to_file_uri "$NEW_PATH")

    # Display info
    echo ""
    log_info "Old path: $OLD_PATH"
    log_info "New path: $NEW_PATH"
    log_info "Encoded old: $ENCODED_OLD"
    log_info "Encoded new: $ENCODED_NEW"

    if [[ "$DRY_RUN" == "true" ]]; then
        echo ""
        log_dryrun "Running in dry-run mode - no changes will be made"
    fi

    if [[ "$REFS_ONLY" == "true" ]]; then
        echo ""
        log_info "Running in refs-only mode - project directory will not be moved"
    fi

    echo ""

    # Set up error trap for rollback
    trap 'rollback' ERR

    # Execute migration steps
    validate
    detect_cursor
    check_cursor_not_running
    find_cursor_workspaces
    create_backup
    backup_cursor_data
    move_project
    rename_claude_dir
    update_project_files
    update_history
    update_cursor_storage_json
    update_cursor_state_vscdb
    update_cursor_workspace_storage
    verify
    verify_cursor_migration
    cleanup

    # Disable trap on success
    trap - ERR

    if [[ "$DRY_RUN" == "true" ]]; then
        log_done "Dry-run complete! No changes were made."
    else
        log_done "Migration complete!"
        if [[ "$REFS_ONLY" != "true" ]]; then
            log_info "Your project is now at: $NEW_PATH"
        fi
    fi
}

main "$@"
